{
  "name": "ngi-firn",
  "private": true,
  "type": "module",
  "version": "0.0.1",
  "description": "A laboratory freezer inventory management system created with Nuxt3, Vue and UnaUI.",
  "author": "Matthias Zepper <MatthiasZepper@users.noreply.github.com>",
  "license": "MIT",
  "homepage": "https://ngisweden.scilifelab.se",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NationalGenomicsInfrastructure/ngi-firn.git"
  },
  "bugs": "https://github.com/NationalGenomicsInfrastructure/ngi-firn/issues",
  "keywords": [
    "ngi",
    "scilifelab",
    "laboratory-management",
    "inventory-system",
    "freezer-management",
    "sample-tracking",
    "scientific-application",
    "laboratory-information-system",
    "genomics",
    "bioinformatics",
    "nuxt",
    "vue",
    "database",
    "web-application"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "nuxi dev",
    "dev-https": "export NODE_EXTRA_CA_CERTS=\"$(mkcert -CAROOT)/rootCA.pem\" && nuxi dev",
    "dev-build-node": "node --env-file=.env .output/server/index.mjs",
    "build": "nuxi build",
    "build-analyze": "NITRO_ANALYZE=1 NITRO_DEBUG=1 nuxi build",
    "start": "node .output/server/index.mjs",
    "typecheck": "npx nuxi typecheck",
    "lint": "eslint .",
    "postinstall": "nuxt prepare",
    "db:init": "tsx scripts/init-db.ts",
    "db:test": "tsx scripts/test-db-connection.ts",
    "db:views": "tsx scripts/ensure-views.ts",
    "db:views:projects": "tsx scripts/pull-project-views.ts"
  },
  "dependencies": {
    "@ibm-cloud/cloudant": "^0.12.22",
    "@iconify-json/lucide": "^1.2.115",
    "@iconify-json/simple-icons": "^1.2.88",
    "@nuxthub/core": "^0.10.7",
    "@pinia/colada": "^1.3.1",
    "@pinia/colada-nuxt": "^1.0.1",
    "@pinia/nuxt": "^0.11.3",
    "@tanstack/vue-table": "^8.21.3",
    "@trpc/client": "^11.18.0",
    "@trpc/server": "^11.18.0",
    "@una-ui/nuxt": "0.67.4",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^14.3.0",
    "h3-zod": "^0.5.3",
    "jose": "^6.2.3",
    "jsbarcode": "^3.12.3",
    "luxon": "^3.7.2",
    "nuxt": "^4.4.8",
    "nuxt-auth-utils": "^0.5.29",
    "pdfmake": "^0.3.11",
    "pinia": "^3.0.4",
    "qrcode": "^1.5.4",
    "qrcode.vue": "^3.10.0",
    "trpc-nuxt": "^2.1.1",
    "zod": "^4.4.3",
    "zxing-wasm": "^3.1.0"
  },
  "devDependencies": {
    "@iconify-json/radix-icons": "^1.2.6",
    "@iconify-json/tabler": "^1.2.35",
    "@nuxt/devtools": "^3.2.4",
    "@nuxt/eslint": "^1.16.0",
    "@types/luxon": "^3.7.2",
    "@types/pdfmake": "^0.3.3",
    "@types/qrcode": "^1.5.6",
    "@unocss/nuxt": "66.7.4",
    "@unocss/preset-wind4": "66.6.2",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "form-data": "4.0.6",
    "rollup-plugin-visualizer": "^7.0.1",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3",
    "unocss": "66.7.4",
    "vue-tsc": "^3.3.6",
    "wrangler": "^4.106.0"
  },
  "packageManager": "pnpm@11.9.0"
}
